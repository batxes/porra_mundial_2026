# Copy to .env.local. All variables are optional.
# With none set, the app runs in local demo mode (localStorage).

# Supabase (auth + persistence). Both required to enable Supabase mode.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# API-Football (server-side results, scorers, cards). Without it the admin panel stays manual.
APIFOOTBALL_API_KEY=your_api_key
