{
  "name": "triliporra",
  "version": "2.0.0",
  "private": true,
  "description": "TRILIPORRA, porra del Mundial 2026 migrada a Next.js y Tailwind.",
  "scripts": {
    "generate:data": "node scripts/generate-legacy-data.mjs",
    "dev": "npm run generate:data && next dev",
    "build": "npm run generate:data && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run generate:data && tsx tests/scoring.test.ts && tsx tests/full-tournament-simulation.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
